{#
/**
 * @file
 * Theme override for ACCESS Active Resource (CiDeR) RP documentation page.
 *
 * Renders the full resource provider documentation page with:
 * - ARA recommendation banner (driven by URL params / localStorage)
 * - Resource title with MFA/account badges
 * - Description from field_rp_description
 * - Login section with SSH dropdown + OnDemand login
 * - File transfer table
 * - Storage table with external storage section
 * - Queue specifications table
 * - Most frequently used software table
 * - Datasets section
 * - Sidebar with support links, office hours, software CTAs, chatbot
 *
 * Field data is accessed directly from the node entity for maximum
 * template control. Paragraph fields are iterated for tabular display.
 */
#}
{%
  set classes = [
    'node',
    'node--type-' ~ node.bundle|clean_class,
    node.isPromoted() ? 'node--promoted',
    node.isSticky() ? 'node--sticky',
    not node.isPublished() ? 'node--unpublished',
    view_mode ? 'node--view-mode-' ~ view_mode|clean_class,
    'rp-documentation',
  ]
%}
{{ attach_library('aspTheme/node') }}

{# Extract field values for easier access in the template #}
{% set rp_description = node.field_rp_description.value %}
{% set mfa_required = node.field_rp_mfa_required.value %}
{% set account_required = node.field_rp_account_required.value %}
{% set ondemand_url = node.field_rp_ondemand_url.0.url %}
{% set office_hours = node.field_rp_office_hours.0 %}
{% set external_storage = node.field_rp_external_storage.value %}
{% set top_software_json = node.field_rp_top_software.value %}
<article{{ attributes.addClass(classes) }}>

  {# ========== ARA Recommendation Banner ========== #}
  <div id="ara-recommendation-banner" class="bg-primary-blue-bg text-primary-blue border-l-4 border-primary-blue p-4 mb-6 hidden">
    <p class="font-bold mb-1">The ACCESS Resource Advisor recommends this resource for your work.</p>
    <p id="ara-recommendation-text" class="m-0 text-sm"></p>
    <button id="ara-dismiss" class="text-sm underline text-primary-blue mt-2 cursor-pointer bg-transparent border-0 p-0">Dismiss</button>
  </div>

  <div class="grid grid-cols-1 gap-8 md--grid-cols-[1fr_25%]">

    {# ========== Main Content Column ========== #}
    <div class="rp-main-content">

      {{ title_prefix }}
      <div class="flex flex-wrap items-center gap-4 mb-4 justify-between">
        <div class="flex gap-4 items-center ms-auto">
          {% if mfa_required %}
            <span class="flex items-center gap-1 text-sm">
              <i class="bi bi-check-circle-fill text-teal"></i> 2FA/MFA
            </span>
          {% endif %}
          {% if account_required %}
            <span class="flex items-center gap-1 text-sm">
              <i class="bi bi-check-circle-fill text-teal"></i> RP account needed
            </span>
          {% endif %}
        </div>
      </div>
      {{ title_suffix }}

      {# --- Description --- #}
      {% if rp_description %}
        <div class="rp-description prose mb-8">
          {{ node.field_rp_description.processed }}
        </div>
      {% endif %}

      {# --- Embedded Chatbot --- #}
      <div class="rp-chatbot mb-8">
        <div class="flex items-center gap-4" style="flex-direction: row-reverse;">
          <button id="rp-chatbot-toggle" data-label="Ask about {{ node.label }}" class="flex items-center justify-center bg-dark-teal text-white cursor-pointer border-0 hover--bg-md-teal" style="width: 60px; height: 60px; border-radius: 50%; flex-shrink: 0;" aria-label="Ask about {{ node.label }}">
            <img src="/themes/contrib/asp-theme/images/icons/ACCESS-arrrow.svg" alt="ACCESS" style="width: 36px; height: 36px;">
          </button>
          <span id="rp-chatbot-tooltip" class="text-white text-sm py-1 px-3 rounded-md whitespace-nowrap" style="background: #107180; position: relative;">Ask about {{ node.label }}<span style="position: absolute; right: -8px; top: 50%; transform: translateY(-50%); width: 0; height: 0; border-top: 8px solid transparent; border-bottom: 8px solid transparent; border-left: 8px solid #107180;"></span></span>
        </div>
        <div id="rp-chatbot-container" class="mt-4 border border-light-gray rounded-md overflow-hidden" style="max-height: 0; opacity: 0; transition: max-height 0.3s ease, opacity 0.3s ease;">
          <div class="embedded-qa-bot" data-resource-context="{{ resource_context }}" style="min-height: 450px;"></div>
        </div>
      </div>

      {# --- Login Section --- #}
      {% set ssh_logins = field_rp_ssh_login_nodes_items %}
      {% if ssh_logins|length > 0 or ondemand_url %}
        <div class="rp-login mb-8">
          <h2>Login to {{ node.label }}</h2>
          <div class="grid grid-cols-1 gap-4 md--grid-cols-2">

            {# SSH Login dropdown — uses paragraph with recommended boolean #}
            {% if ssh_logins|length > 0 %}
              <div class="border-2 border-dark-teal rounded-md p-4">
                <h3 class="text-lg font-bold mt-0 mb-3">SSH Login</h3>
                {% set first_hostname = ssh_logins[0].field_rp_ssh_url.uri|replace({'https://': '', 'http://': ''}) %}
                {% for login in ssh_logins %}
                  {% if login.field_rp_recommended.value %}
                    {% set first_hostname = login.field_rp_ssh_url.uri|replace({'https://': '', 'http://': ''}) %}
                  {% endif %}
                {% endfor %}
                <select id="rp-ssh-login-select" class="w-full border border-gray rounded-md p-2 mb-2">
                  {% for login in ssh_logins %}
                    {% set hostname = login.field_rp_ssh_url.uri|replace({'https://': '', 'http://': ''}) %}
                    {% set is_recommended = login.field_rp_recommended.value %}
                    <option value="{{ hostname }}" {{ is_recommended ? 'selected' : '' }}>
                      {{ login.field_rp_ssh_url.title ?: hostname }}{% if is_recommended %} | RECOMMENDED{% endif %}
                    </option>
                  {% endfor %}
                </select>
                <div class="overflow-x-auto bg-light-gray rounded-md mb-3">
                  <code id="rp-ssh-command" class="not-prose block p-2 text-sm whitespace-nowrap">$ ssh &lt;your_username&gt;@<span id="rp-ssh-hostname">{{ first_hostname }}</span></code>
                </div>

                {# Login help links #}
                {% set login_help = node.field_rp_login_help_links %}
                {% if login_help|length > 0 %}
                  <div class="flex flex-wrap gap-3 text-sm">
                    {% for link in login_help %}
                      <a href="{{ link.uri|replace({'internal:': ''}) }}" class="flex items-center gap-1 text-md-teal no-underline hover--underline">
                        <i class="bi bi-play-circle"></i> {{ link.title ?: link.uri|replace({'internal:': '', 'https://': '', 'http://': ''}) }}
                      </a>
                    {% endfor %}
                  </div>
                {% endif %}
              </div>
            {% endif %}

            {# OnDemand Login #}
            {% if ondemand_url %}
              <div class="border-2 border-dark-teal rounded-md p-4">
                <h3 class="text-lg font-bold mt-0 mb-3">ACCESS OnDemand Login</h3>
                <a href="{{ ondemand_url }}" class="btn btn-primary">
                  LOGIN
                </a>
                <div class="mt-3">
                  <a href="https://ondemand.connectci.org" class="text-sm text-md-teal no-underline hover--underline flex items-center gap-1">
                    <i class="bi bi-box-arrow-up-right"></i> How do I use ACCESS OnDemand?
                  </a>
                </div>
              </div>
            {% endif %}
          </div>

          {# Account setup link #}
          {% set account_setup = node.field_rp_account_setup_url %}
          {% if account_setup|length > 0 %}
            <div class="mt-3">
              <a href="{{ account_setup.0.uri|replace({'internal:': ''}) }}" class="text-md-teal no-underline hover--underline">
                {{ account_setup.0.title ?: 'RP Account Setup' }}
              </a>
            </div>
          {% endif %}
        </div>
      {% endif %}

      {# --- File Transfer Table --- #}
      {% if field_rp_file_transfer_items|length > 0 %}
        <div class="rp-file-transfer mb-8">
          <h2>File Transfer</h2>
          <p class="text-sm text-dark-gray mb-3">Use Globus for large transfers. SCP and Rsync are recommended for small to medium-sized transfers only.</p>
          <div class="overflow-x-auto">
            <table class="w-full border-collapse">
              <thead>
                <tr class="border-b-2 border-gray">
                  <th class="text-left py-2 pr-4 font-semibold">Supported Methods</th>
                  <th class="text-left py-2 pr-4 font-semibold">Data Transfer Node</th>
                  <th class="text-left py-2 font-semibold">URL</th>
                </tr>
              </thead>
              <tbody>
                {% for paragraph in field_rp_file_transfer_items %}
                  {% if paragraph.field_rp_method.value|default('') %}
                  <tr class="border-b border-light-gray">
                    <td class="py-2 pr-4">
                      {{ paragraph.field_rp_method.value|default('')|upper }}
                      {% if paragraph.field_rp_recommended.value %}
                        <span class="text-xs font-bold text-dark-gray">| RECOMMENDED</span>
                      {% endif %}
                    </td>
                    <td class="py-2 pr-4">{{ paragraph.field_rp_transfer_node.value|default('') }}</td>
                    <td class="py-2">
                      {% if paragraph.field_rp_transfer_url.0.uri %}
                        <a href="{{ paragraph.field_rp_transfer_url.0.uri|replace({'internal:': ''}) }}" class="text-md-teal no-underline hover--underline">
                          {{ paragraph.field_rp_transfer_url.0.title ?: paragraph.field_rp_transfer_url.0.uri|replace({'internal:': ''}) }}
                        </a>
                      {% endif %}
                    </td>
                  </tr>
                  {% endif %}
                {% endfor %}
              </tbody>
            </table>
          </div>
        </div>
      {% endif %}

      {# --- Storage Section --- #}
      {% if field_rp_storage_items|length > 0 or external_storage %}
        <div class="rp-storage mb-8">
          <h2>Storage</h2>

          {# File System Table #}
          {% if field_rp_storage_items|length > 0 %}
            <h3 class="text-teal font-bold">File System</h3>
            <div class="overflow-x-auto">
              <table class="w-full border-collapse">
                <thead>
                  <tr class="border-b-2 border-gray">
                    <th class="text-left py-2 pr-4 font-semibold">Directory</th>
                    <th class="text-left py-2 pr-4 font-semibold">Path</th>
                    <th class="text-left py-2 pr-4 font-semibold">Quota</th>
                    <th class="text-left py-2 pr-4 font-semibold">Purge</th>
                    <th class="text-left py-2 pr-4 font-semibold">Backup</th>
                    <th class="text-left py-2 font-semibold">Notes</th>
                  </tr>
                </thead>
                <tbody>
                  {% for paragraph in field_rp_storage_items %}
                    {% if paragraph.field_rp_directory.value|default('') %}
                    <tr class="border-b border-light-gray">
                      <td class="py-2 pr-4 font-semibold">{{ paragraph.field_rp_directory.value|default('') }}</td>
                      <td class="py-2 pr-4"><code>{{ paragraph.field_rp_fs_path.value|default('') }}</code></td>
                      <td class="py-2 pr-4">{{ paragraph.field_rp_quota.value|default('') }}</td>
                      <td class="py-2 pr-4">{{ paragraph.field_rp_purge.value|default('') }}</td>
                      <td class="py-2 pr-4">{{ paragraph.field_rp_backup.value|default('') }}</td>
                      <td class="py-2">{{ paragraph.field_rp_fs_notes.value|default('') }}</td>
                    </tr>
                    {% endif %}
                  {% endfor %}
                </tbody>
              </table>
            </div>
          {% endif %}

          {# External Storage #}
          {% if external_storage %}
            <h3 class="text-teal font-bold mt-6">External Storage</h3>
            <div class="prose">
              {{ node.field_rp_external_storage.processed }}
            </div>
          {% endif %}
        </div>
      {% endif %}

    </div>{# /.rp-main-content #}

    {# ========== Sidebar (top section) ========== #}
    <aside class="rp-sidebar">

      {# Support Links #}
      {% set support_links = node.field_rp_support_links %}
      {% if support_links|length > 0 or office_hours %}
        <div class="bg-dark-teal text-white p-4 mb-4">
          <h3 class="mt-0 text-lg font-bold text-white">Get Support</h3>
          {% if support_links|length > 0 %}
            <ul class="list-none p-0 m-0 mb-3 font-normal">
              {% for link in support_links %}
                <li class="mb-2">
                  <a href="{{ link.uri|replace({'internal:': ''}) }}" class="text-white no-underline hover--underline hover--text-white font-normal">
                    {{ link.title ?: link.uri|replace({'internal:': '', 'https://': '', 'http://': ''}) }}
                  </a>
                </li>
              {% endfor %}
            </ul>
          {% endif %}
          {% if office_hours %}
            <div class="border-t border-md-teal pt-3">
              <p class="font-bold mb-1 text-sm">OFFICE HOURS</p>
              <a href="{{ office_hours.uri|replace({'internal:': ''}) }}" class="text-white no-underline hover--underline hover--text-white font-normal text-sm">
                {{ office_hours.title ?: 'View Office Hours' }}
              </a>
            </div>
          {% endif %}
        </div>
      {% endif %}

      {# In-page Navigation #}
      <div class="bg-dark-teal text-white p-4 mb-4">
        <h3 class="mt-0 text-lg font-bold text-white">{{ node.label }}</h3>
        <ul class="list-none p-0 m-0">
          {% if field_rp_ssh_login_nodes_items|length > 0 or ondemand_url %}
            <li class="mb-1"><a href="#" class="text-white no-underline hover--underline hover--text-white text-sm" onclick="document.querySelector('.rp-login').scrollIntoView({behavior:'smooth'});return false;">Login Information</a></li>
          {% endif %}
          {% if field_rp_file_transfer_items|length > 0 %}
            <li class="mb-1"><a href="#" class="text-white no-underline hover--underline hover--text-white text-sm" onclick="document.querySelector('.rp-file-transfer').scrollIntoView({behavior:'smooth'});return false;">File Transfer</a></li>
          {% endif %}
          {% if field_rp_storage_items|length > 0 or external_storage %}
            <li class="mb-1"><a href="#" class="text-white no-underline hover--underline hover--text-white text-sm" onclick="document.querySelector('.rp-storage').scrollIntoView({behavior:'smooth'});return false;">Storage</a></li>
          {% endif %}
          {% if field_rp_queue_specs_items|length > 0 %}
            <li class="mb-1"><a href="#" class="text-white no-underline hover--underline hover--text-white text-sm" onclick="document.querySelector('.rp-queue-specs').scrollIntoView({behavior:'smooth'});return false;">Jobs</a></li>
          {% endif %}
          {% if top_software_json %}
            <li class="mb-1"><a href="#" class="text-white no-underline hover--underline hover--text-white text-sm" onclick="document.querySelector('.rp-top-software').scrollIntoView({behavior:'smooth'});return false;">Frequently Used Software</a></li>
          {% endif %}
          {% if field_rp_datasets_items|length > 0 %}
            <li class="mb-1"><a href="#" class="text-white no-underline hover--underline hover--text-white text-sm" onclick="document.querySelector('.rp-datasets').scrollIntoView({behavior:'smooth'});return false;">Datasets</a></li>
          {% endif %}
        </ul>
      </div>

      {# Software CTA: RP's official software page #}
      {% set software_list_url = node.field_rp_software_list_url.0 %}
      {% if software_list_url %}
        <div class="bg-dark-teal text-white p-4 mb-4">
          <h3 class="mt-0 text-lg font-bold text-white">SEE ALL SOFTWARE AVAILABLE ON {{ node.label|upper }}</h3>
          <a href="{{ software_list_url.uri|replace({'internal:': ''}) }}" class="btn btn-primary">
            {{ software_list_url.title ?: 'VIEW SOFTWARE' }}
          </a>
        </div>
      {% endif %}

      {# Software CTA: SDS explorer — conditional on whether SDS has data for this resource #}
      {% if sds_has_software and sds_resource_name %}
        <div class="bg-dark-teal text-white p-4 mb-4">
          <h3 class="mt-0 text-lg font-bold text-white">EXPLORE SOFTWARE AVAILABLE ON {{ node.label|upper }}</h3>
          <a href="https://sds.access-ci.org/?installed_on={{ sds_resource_name }}" class="btn btn-primary">
            EXPLORE IN SDS
          </a>
        </div>
      {% else %}
        <div class="bg-light-gray p-4 mb-4">
          <p class="text-sm text-dark-gray m-0">{{ node.label }} is not currently reporting available software to the <a href="https://sds.access-ci.org" class="text-md-teal no-underline hover--underline">Software Discovery Service</a>.</p>
        </div>
      {% endif %}

    </aside>{# /.rp-sidebar (top) #}

  </div>{# /.grid (top section) #}

  {# ========== Jobs / Queue Specifications (full width) ========== #}
  {% set jobs_info = node.field_rp_jobs_info.value %}
  {% if field_rp_queue_specs_items|length > 0 or jobs_info %}
    <div class="rp-queue-specs mb-8">
      <h2>Jobs</h2>
      {% if jobs_info %}
        <div class="prose mb-6">
          {{ node.field_rp_jobs_info.processed }}
        </div>
      {% endif %}
      {% if field_rp_queue_specs_items|length > 0 %}
        <h3>Queue specifications</h3>
          {% if queue_metrics_updated %}
            <p class="text-xs text-dark-gray mb-2">Metrics updated {{ queue_metrics_updated }}</p>
          {% endif %}
          <div class="overflow-x-auto">
            <table class="w-full border-collapse">
              <thead>
                <tr class="border-b-2 border-gray">
                  <th class="text-left py-2 pr-4 font-semibold align-bottom">Name</th>
                  <th class="text-left py-2 pr-4 font-semibold align-bottom">Purpose</th>
                  <th class="text-left py-2 pr-4 font-semibold align-bottom">CPUs</th>
                  <th class="text-left py-2 pr-4 font-semibold align-bottom">GPUs</th>
                  <th class="text-left py-2 pr-4 font-semibold align-bottom">RAM</th>
                  <th class="text-right py-2 pr-4 font-semibold align-bottom">Jobs
                    <div class="font-normal text-xs text-dark-gray">30 days</div>
                  </th>
                  <th class="text-left py-2 pr-4 font-semibold align-bottom">Wait Time
                    <div class="font-normal text-xs text-dark-gray">30-day trend</div>
                  </th>
                  <th class="text-left py-2 font-semibold align-bottom">Wall Time
                    <div class="font-normal text-xs text-dark-gray">30-day trend</div>
                  </th>
                </tr>
              </thead>
              <tbody>
                {% for paragraph in field_rp_queue_specs_items %}
                  {% set qname = paragraph.field_rp_queue_name.value|default('') %}
                  {% if qname %}
                  {% set qmetrics = queue_metrics[qname] ?? null %}
                  <tr class="border-b border-light-gray">
                    <td class="py-2 pr-4 font-semibold">{{ qname }}</td>
                    <td class="py-2 pr-4 text-sm">
                      {{ paragraph.field_rp_queue_purpose.value|default('') }}
                    </td>
                    <td class="py-2 pr-4">{{ paragraph.field_rp_cpus.value|default('') }}</td>
                    <td class="py-2 pr-4">{{ paragraph.field_rp_gpus.value|default('') }}</td>
                    <td class="py-2 pr-4">{{ paragraph.field_rp_ram.value|default('') }}</td>
                    <td class="py-2 pr-4 text-right">
                      {% if qmetrics and qmetrics.job_count is not null %}
                        {{ qmetrics.job_count|number_format(0) }}
                      {% else %}
                        <span class="text-dark-gray">&mdash;</span>
                      {% endif %}
                    </td>
                    <td class="py-2 pr-4">
                      {% if qmetrics and qmetrics.daily_wait|default([])|length > 1 %}
                        {% set vals = qmetrics.daily_wait %}
                        {% set avg = qmetrics.wait_time %}
                        {% set spark_max = vals|first %}
                        {% for v in vals %}{% if v > spark_max %}{% set spark_max = v %}{% endif %}{% endfor %}
                        {% set spark_min = spark_max %}
                        {% for v in vals %}{% if v < spark_min %}{% set spark_min = v %}{% endif %}{% endfor %}
                        {% if spark_max > 0 %}
                          {% set avg_y = (30 - (avg / spark_max * 28))|round(1) %}
                          {% set avg_y = avg_y < 2 ? 2 : (avg_y > 30 ? 30 : avg_y) %}
                          <div class="inline-flex flex-col items-start">
                            <svg class="rp-sparkline" width="120" height="32" viewBox="0 0 120 32" role="img" focusable="false" aria-labelledby="wait-title-{{ loop.index }}">
                              <title id="wait-title-{{ loop.index }}">{{ qname }} wait time: average {{ avg|number_format(1) }} hours, range {{ spark_min|round(1) }} to {{ spark_max|round(1) }} hours over 30 days</title>
                              <line x1="1" y1="{{ avg_y }}" x2="90" y2="{{ avg_y }}" stroke="#999" stroke-width="0.75" stroke-dasharray="3,2" />
                              <polyline fill="none" stroke="#107180" stroke-width="1.5"
                                points="{% for v in vals %}{{ (loop.index0 / (vals|length - 1) * 88 + 1)|round(1) }},{{ (30 - (v / spark_max * 28))|round(1) }}{% if not loop.last %} {% endif %}{% endfor %}" />
                              <text x="93" y="{{ (avg_y + 4)|round(1) }}" font-size="11" fill="#666">{{ avg|number_format(1) }}</text>
                            </svg>
                            <span class="text-xs text-dark-gray" aria-hidden="true">{{ spark_min|round(1) }}–{{ spark_max|round(1) }} hrs</span>
                          </div>
                        {% else %}
                          <span>0</span>
                          <span class="sr-only">{{ qname }} wait time: 0 hours</span>
                        {% endif %}
                      {% elseif qmetrics and qmetrics.wait_time is not null %}
                        {{ qmetrics.wait_time|number_format(1) }}
                        <span class="sr-only">hours</span>
                      {% else %}
                        <span class="text-dark-gray" aria-label="No data">&mdash;</span>
                      {% endif %}
                    </td>
                    <td class="py-2">
                      {% if qmetrics and qmetrics.daily_wall|default([])|length > 1 %}
                        {% set vals = qmetrics.daily_wall %}
                        {% set avg = qmetrics.wall_time %}
                        {% set spark_max = vals|first %}
                        {% for v in vals %}{% if v > spark_max %}{% set spark_max = v %}{% endif %}{% endfor %}
                        {% set spark_min = spark_max %}
                        {% for v in vals %}{% if v < spark_min %}{% set spark_min = v %}{% endif %}{% endfor %}
                        {% if spark_max > 0 %}
                          {% set avg_y = (30 - (avg / spark_max * 28))|round(1) %}
                          {% set avg_y = avg_y < 2 ? 2 : (avg_y > 30 ? 30 : avg_y) %}
                          <div class="inline-flex flex-col items-start">
                            <svg class="rp-sparkline" width="120" height="32" viewBox="0 0 120 32" role="img" focusable="false" aria-labelledby="wall-title-{{ loop.index }}">
                              <title id="wall-title-{{ loop.index }}">{{ qname }} wall time: average {{ avg|number_format(1) }} hours, range {{ spark_min|round(1) }} to {{ spark_max|round(1) }} hours over 30 days</title>
                              <line x1="1" y1="{{ avg_y }}" x2="90" y2="{{ avg_y }}" stroke="#999" stroke-width="0.75" stroke-dasharray="3,2" />
                              <polyline fill="none" stroke="#107180" stroke-width="1.5"
                                points="{% for v in vals %}{{ (loop.index0 / (vals|length - 1) * 88 + 1)|round(1) }},{{ (30 - (v / spark_max * 28))|round(1) }}{% if not loop.last %} {% endif %}{% endfor %}" />
                              <text x="93" y="{{ (avg_y + 4)|round(1) }}" font-size="11" fill="#666">{{ avg|number_format(1) }}</text>
                            </svg>
                            <span class="text-xs text-dark-gray" aria-hidden="true">{{ spark_min|round(1) }}–{{ spark_max|round(1) }} hrs</span>
                          </div>
                        {% else %}
                          <span>0</span>
                          <span class="sr-only">{{ qname }} wall time: 0 hours</span>
                        {% endif %}
                      {% elseif qmetrics and qmetrics.wall_time is not null %}
                        {{ qmetrics.wall_time|number_format(1) }}
                        <span class="sr-only">hours</span>
                      {% else %}
                        <span class="text-dark-gray" aria-label="No data">&mdash;</span>
                      {% endif %}
                    </td>
                  </tr>
                  {% endif %}
                {% endfor %}
              </tbody>
            </table>
          </div>
          {% endif %}
        </div>
      {% endif %}

  {# ========== Most Frequently Used Software (full width) ========== #}
  {% if top_software|length > 0 %}
    <div class="rp-top-software mb-8">
      <h2>Most Frequently Used Software</h2>
      <p class="text-sm text-dark-gray mb-3">The following software packages are among the most frequently used on {{ node.label }}, based on job data from <a href="https://xdmod.access-ci.org" class="text-md-teal no-underline hover--underline">XDMoD</a>.</p>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse">
          <thead>
            <tr class="border-b-2 border-gray">
              <th class="text-left py-2 pr-4 font-semibold">Application</th>
              <th class="text-left py-2 pr-4 font-semibold">Description</th>
              <th class="text-left py-2 pr-4 font-semibold">Research Discipline</th>
              <th class="text-right py-2 font-semibold">Jobs</th>
            </tr>
          </thead>
          <tbody>
            {% for software in top_software %}
              <tr class="border-b border-light-gray">
                <td class="py-2 pr-4 font-semibold whitespace-nowrap">
                  {%- if software.web_page -%}
                    <a href="{{ software.web_page }}" class="text-md-teal no-underline hover--underline">{{ software.name }}</a>
                  {%- else -%}
                    {{ software.name }}
                  {%- endif -%}
                </td>
                <td class="py-2 pr-4 text-sm">{{ software.description|default('') }}</td>
                <td class="py-2 pr-4 text-sm">{{ software.research_field|default('') }}</td>
                <td class="py-2 text-right whitespace-nowrap">{{ software.job_count|number_format }}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  {% endif %}

  {# ========== Datasets (full width) ========== #}
  {% if field_rp_datasets_items|length > 0 %}
    <div class="rp-datasets mb-8">
      <h2>Datasets</h2>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse">
          <thead>
            <tr class="border-b-2 border-gray">
              <th class="text-left py-2 pr-4 font-semibold">Name</th>
              <th class="text-left py-2 font-semibold">Description</th>
            </tr>
          </thead>
          <tbody>
            {% for paragraph in field_rp_datasets_items %}
              {% if paragraph.field_rp_dataset_name.value|default('') %}
              <tr class="border-b border-light-gray">
                <td class="py-2 pr-4 font-semibold">{{ paragraph.field_rp_dataset_name.value }}</td>
                <td class="py-2 text-sm">{{ paragraph.field_rp_dataset_description.value|default('') ? paragraph.field_rp_dataset_description.processed : '' }}</td>
              </tr>
              {% endif %}
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  {% endif %}

</article>

{# ========== ARA Banner JavaScript ========== #}
<script>
(function() {
  var banner = document.getElementById('ara-recommendation-banner');
  var textEl = document.getElementById('ara-recommendation-text');
  var dismissBtn = document.getElementById('ara-dismiss');
  var storageKey = 'ara_recommendation_{{ node.id }}';

  // Check URL params first, then localStorage
  var params = new URLSearchParams(window.location.search);
  var araContext = params.get('ara_context');

  if (araContext) {
    localStorage.setItem(storageKey, araContext);
  } else {
    araContext = localStorage.getItem(storageKey);
  }

  if (araContext) {
    textEl.textContent = araContext;
    banner.classList.remove('hidden');
  }

  if (dismissBtn) {
    dismissBtn.addEventListener('click', function() {
      localStorage.removeItem(storageKey);
      banner.classList.add('hidden');
    });
  }
})();
</script>

{# ========== SSH Login Selector JavaScript ========== #}
<script>
(function() {
  var select = document.getElementById('rp-ssh-login-select');
  var hostname = document.getElementById('rp-ssh-hostname');
  if (select && hostname) {
    select.addEventListener('change', function() {
      hostname.textContent = this.value;
    });
  }
})();
</script>

{# ========== Chatbot Toggle JavaScript ========== #}
<script>
(function() {
  var toggle = document.getElementById('rp-chatbot-toggle');
  var container = document.getElementById('rp-chatbot-container');
  var tooltip = document.getElementById('rp-chatbot-tooltip');
  var isOpen = false;
  function toggleChat() {
    isOpen = !isOpen;
    if (isOpen) {
      container.style.maxHeight = container.scrollHeight + 'px';
      container.style.opacity = '1';
    } else {
      container.style.maxHeight = '0';
      container.style.opacity = '0';
    }
    if (tooltip) {
      tooltip.style.opacity = isOpen ? '0' : '1';
      tooltip.style.transition = 'opacity 0.3s ease';
    }
  }
  if (toggle && container) {
    toggle.addEventListener('click', toggleChat);
    if (tooltip) {
      tooltip.style.cursor = 'pointer';
      tooltip.addEventListener('click', toggleChat);
    }
  }
})();
</script>
