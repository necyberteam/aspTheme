{#
/**
 * @file
 * Theme override for the RP Documentation Index view.
 *
 * Adds ARA recommendation banner support: when ?ara_context= is present,
 * highlights the targeted resource group and auto-scrolls to it.
 */
#}
{%
  set classes = [
    'view',
    'view-' ~ id|clean_class,
    'view-id-' ~ id,
    'view-display-id-' ~ display_id,
    dom_id ? 'js-view-dom-id-' ~ dom_id,
  ]
%}
<div{{ attributes.addClass(classes) }}>
  {{ title_suffix }}
  {% if header %}
    {# Intro text and the ARA "find the best resource" CTA share a full-width
       header row so the listing below can span the full content width (the
       left documentation menu already occupies a column on this page). #}
    <header class="mb-5 flex flex-col gap-4 md--flex-row md--items-start">
      <div class="text-dark-teal prose text-2xl pe-10 flex-1">
        {{ header }}
        {% if can_edit_resources or can_edit_resource_groups %}
          <div class="rp-admin-actions mb-4 flex flex-wrap gap-2 [&_.btn]--m-0">
            {% if can_edit_resources %}
              <a href="/rp-resources/manage" class="btn btn-sm btn-outline-secondary">{{ 'Manage Resources'|t }}</a>
            {% endif %}
            {% if can_edit_resource_groups %}
              <a href="/rp-groups/manage" class="btn btn-sm btn-outline-secondary">{{ 'Manage Resource Groups'|t }}</a>
            {% endif %}
          </div>
        {% endif %}
      </div>
      <div class="rp-ara-cta bg-dark-teal text-white p-4 md--w-1/4 md--shrink-0">
        <h3 class="mt-0 uppercase font-semibold text-sm font-bold text-white">{{ 'Find the best resource for your project'|t }}</h3>
        <a href="https://ara.access-ci.org/" class="text-sm text-white no-underline hover--text-white hover--underline ">{{ 'Try the ACCESS Resource Advisor'|t }} &nbsp;<i class="bi bi-arrow-right"></i></a>
      </div>
    </header>
  {% endif %}
  {% if exposed %}
    <div class="view-filters">
      {{ exposed }}
    </div>
  {% endif %}
  {% if attachment_before %}
    <div class="attachment attachment-before">
      {{ attachment_before }}
    </div>
  {% endif %}

  {% if rows %}
    {# Full-width listing: the ARA CTA moved to the header above, so the
       resource content uses the entire available column width. #}
    <div class="view-content rp-listing-main">
      {{ rows }}
    </div>
  {% elseif empty %}
    <div class="view-empty">
      {{ empty }}
    </div>
  {% endif %}

  {% if pager %}
    {{ pager }}
  {% endif %}
  {% if attachment_after %}
    <div class="attachment attachment-after">
      {{ attachment_after }}
    </div>
  {% endif %}
  {% if more %}
    {{ more }}
  {% endif %}
  {% if footer %}
    <footer>
      {{ footer }}
    </footer>
  {% endif %}
  {% if feed_icons %}
    <div class="feed-icons">
      {{ feed_icons }}
    </div>
  {% endif %}
</div>

{# ARA Recommendation Banner JS #}
<script>
(function() {
  var STORAGE_KEY = 'ara_rp_recommendations';

  // Load stored recommendations.
  function loadRecs() {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY)) || []; }
    catch(e) { return []; }
  }

  function saveRecs(recs) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(recs));
  }

  // Parse new recommendations from URL.
  // Supports: ?ara_context=...&ara_group=slug (single)
  //       or: ?ara_context=...&ara_group=slug1,slug2 (multiple groups, same context)
  //       or: ?ara_recs=slug1:context1;slug2:context2 (multiple with different contexts)
  var params = new URLSearchParams(window.location.search);
  var newRecs = [];

  var araRecs = params.get('ara_recs');
  if (araRecs) {
    // Format: slug1:context1;slug2:context2
    araRecs.split(';').forEach(function(pair) {
      var parts = pair.split(':');
      if (parts.length >= 2) {
        newRecs.push({ group: parts[0].trim(), context: parts.slice(1).join(':').trim() });
      }
    });
  } else {
    var araContext = params.get('ara_context');
    var araGroup = params.get('ara_group');
    if (araContext && araGroup) {
      // Support comma-separated groups with shared context.
      araGroup.split(',').forEach(function(slug) {
        slug = slug.trim();
        if (slug) {
          newRecs.push({ group: slug, context: araContext });
        }
      });
    }
  }

  // Merge new recs into stored, replacing duplicates by group slug.
  var stored = loadRecs();
  newRecs.forEach(function(rec) {
    var idx = stored.findIndex(function(s) { return s.group === rec.group; });
    if (idx >= 0) {
      stored[idx] = rec;
    } else {
      stored.push(rec);
    }
  });
  if (newRecs.length > 0) {
    saveRecs(stored);
  }

  // Show banners for all active recommendations.
  var highlightedTargets = [];
  stored.forEach(function(rec) {
    var target = document.getElementById('group-' + rec.group);
    if (!target) return;

    var banner = target.querySelector('.ara-group-banner');
    if (banner) {
      banner.querySelector('.ara-banner-text').textContent = rec.context;
      banner.classList.remove('hidden');
    }

    // Pass ara_context through to resource links.
    var links = target.querySelectorAll('.rp-resource-list-link');
    for (var i = 0; i < links.length; i++) {
      var href = links[i].getAttribute('href');
      var sep = href.indexOf('?') === -1 ? '?' : '&';
      links[i].setAttribute('href', href + sep + 'ara_context=' + encodeURIComponent(rec.context));
    }

    highlightedTargets.push(target);
  });

  // Scroll to the first highlighted group in DOM order.
  if (newRecs.length > 0 && highlightedTargets.length > 0) {
    highlightedTargets.sort(function(a, b) {
      return a.compareDocumentPosition(b) & Node.DOCUMENT_POSITION_FOLLOWING ? -1 : 1;
    });
    setTimeout(function() {
      highlightedTargets[0].scrollIntoView({ behavior: 'smooth', block: 'start' });
    }, 300);
  }

  // Dismiss buttons — remove just that group's recommendation.
  document.querySelectorAll('.ara-dismiss').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var row = btn.closest('.rp-resource-group-row');
      var slug = row ? row.id.replace('group-', '') : null;

      btn.closest('.ara-group-banner').classList.add('hidden');

      if (slug) {
        var recs = loadRecs().filter(function(r) { return r.group !== slug; });
        saveRecs(recs);
      }
    });
  });
})();
</script>
