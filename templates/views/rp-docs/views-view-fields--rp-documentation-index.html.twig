{#
/**
 * @file
 * Theme override for a row in the RP Documentation Index view.
 *
 * For resource_group nodes, renders the child resources as an inline table
 * so users can see the group contents without clicking through.
 * Supports ARA recommendation banners via ara_context URL parameter.
 *
 * Available variables:
 * - view: The view object.
 * - fields: All field handler objects for the current row.
 * - row: The raw result row from the query.
 * - rp_group_resources: Array of child resources (for resource_group rows).
 * - rp_group_slug: URL-safe slug for anchor links (for resource_group rows).
 * - rp_node_id: Node ID for this row.
 */
#}
<div{% if rp_group_slug %} id="group-{{ rp_group_slug }}"{% endif %} class="rp-listing-row{% if rp_group_slug %} rp-resource-group-row{% endif %}">

{% for field in fields -%}
  {{ field.separator }}
  {%- if field.wrapper_element -%}
    <{{ field.wrapper_element }}{{ field.wrapper_attributes }}>
  {%- endif %}
  {%- if field.label -%}
    {%- if field.label_element -%}
      <{{ field.label_element }}{{ field.label_attributes }}>{{ field.label }}{{ field.label_suffix }}</{{ field.label_element }}>
    {%- else -%}
      {{ field.label }}{{ field.label_suffix }}
    {%- endif -%}
  {%- endif -%}
  {%- if field.element_type -%}
    <{{ field.element_type }}{{ field.element_attributes }}>{{ field.content }}</{{ field.element_type }}>
  {%- else -%}
    {{ field.content }}
  {%- endif -%}
  {%- if field.wrapper_element -%}
    </{{ field.wrapper_element }}>
  {%- endif -%}
{%- endfor %}

{# Inline resources table for Resource Group nodes #}
{% if rp_group_resources|length > 0 %}
  {# ARA recommendation banner — shown when ara_context targets this group #}
  <div class="ara-group-banner bg-primary-blue-bg text-primary-blue border-l-4 border-primary-blue p-3 mb-3 mt-3 hidden" data-group-slug="{{ rp_group_slug }}" data-node-id="{{ rp_node_id }}">
    <p class="font-bold mb-1 text-sm">Recommended by the ACCESS Resource Advisor</p>
    <p class="ara-banner-text m-0 text-sm"></p>
    <button class="ara-dismiss text-xs underline text-primary-blue mt-1 cursor-pointer bg-transparent border-0 p-0">Dismiss</button>
  </div>

  <div class="rp-resource-group-list mt-3">
    <table class="w-full border-collapse text-sm">
      <thead>
        <tr class="border-b border-gray">
          <th class="text-left py-1 pr-4 font-semibold">Resource</th>
          <th class="text-left py-1 font-semibold">Description</th>
        </tr>
      </thead>
      <tbody>
        {% for resource in rp_group_resources %}
          <tr class="border-b border-light-gray">
            <td class="py-2 pr-4 whitespace-nowrap">
              <a href="{{ resource.url }}" class="text-md-teal no-underline hover--underline rp-resource-link">
                {{ resource.title }}
              </a>
            </td>
            <td class="py-2 text-sm">
              {{ resource.description|raw }}
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
{% endif %}

</div>
